# Variables de entorno para la configuración del cliente de Firebase.
# Copia este archivo a .env.local y reemplaza los valores con los de tu proyecto de Firebase.
# Puedes encontrar estos valores en la Consola de Firebase -> Configuración del Proyecto -> General -> Tus apps -> Configuración del SDK.

# Clave de API web de Firebase
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy... "
# Dominio de autenticación de Firebase
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
# ID de tu proyecto de Firebase
NEXT_PUBLIC_FIREBASE_PROJECT_ID="tu-proyecto"
# Bucket de almacenamiento de Firebase
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="tu-proyecto.appspot.com"
# ID del remitente de mensajería de Firebase
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
# ID de tu aplicación web de Firebase
NEXT_PUBLIC_FIREBASE_APP_ID="1:12345:web:abcd..."